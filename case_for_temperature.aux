\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textcolor {purple}{TODO: change the font so it's the same as the other figures}\textbf  {(a)} The northern Sierra Nevada study region with terrain elevation. Outlines depict the Yuba, North Fork American, Lake Tahoe, and Truckee HUC8 watershed boundaries. Red open diamonds depict the location of NRCS SNOTEL sites, open black circles show the location of the four USHCN stations in the region, and the open blue square depicts the CSSL energy balance site. \textbf  {(b)} The CSSL meteorological tower in winter, \textbf  {(c)} a close-up view of the Campbell CNR4 radiometer and IRGASON eddy covariance system, and \textbf  {(d)} an aerial overview of the CSSL site. The location of the forest meteorological tower (not shown) is located just outside of the frame. }}{12}{figure.1}\protected@file@percent }
\newlabel{fig:region_map}{{1}{12}{\todo {change the font so it's the same as the other figures}\textbf {(a)} The northern Sierra Nevada study region with terrain elevation. Outlines depict the Yuba, North Fork American, Lake Tahoe, and Truckee HUC8 watershed boundaries. Red open diamonds depict the location of NRCS SNOTEL sites, open black circles show the location of the four USHCN stations in the region, and the open blue square depicts the CSSL energy balance site. \textbf {(b)} The CSSL meteorological tower in winter, \textbf {(c)} a close-up view of the Campbell CNR4 radiometer and IRGASON eddy covariance system, and \textbf {(d)} an aerial overview of the CSSL site. The location of the forest meteorological tower (not shown) is located just outside of the frame}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces  \textbf  {(a)} The 500 mb geopotential height anomaly during the March 2026 heatwave from ERA5 for six days across the western USA. The study region outlined by a black rectangle. Gray stippling indicates regions with a geopotential height greater than 2-$\sigma $ above the 1950-2022 mean for the month of March. \textbf  {(b-c)} show the timeseries of meteorological conditions at CSSL prior to and during the heatwave event. \textbf  {(b)} depicts daily average air temperature and daily precipitation rate. Days with a majority of rain (red) and a majority of snowfall (blue) are differentiated. \textbf  {(c)} depicts the daily SWE and the one-day change in SWE (dSWE; right axis). Days with a positive dSWE (blue) are denoted by accumulation and days with a negative dSWE (red) are termed melt days, acknowledging that some SWE may be lost by other processes. }}{13}{figure.2}\protected@file@percent }
\newlabel{fig:era5_anoms}{{2}{13}{\textbf {(a)} The 500 mb geopotential height anomaly during the March 2026 heatwave from ERA5 for six days across the western USA. The study region outlined by a black rectangle. Gray stippling indicates regions with a geopotential height greater than 2-$\sigma $ above the 1950-2022 mean for the month of March. \textbf {(b-c)} show the timeseries of meteorological conditions at CSSL prior to and during the heatwave event. \textbf {(b)} depicts daily average air temperature and daily precipitation rate. Days with a majority of rain (red) and a majority of snowfall (blue) are differentiated. \textbf {(c)} depicts the daily SWE and the one-day change in SWE (dSWE; right axis). Days with a positive dSWE (blue) are denoted by accumulation and days with a negative dSWE (red) are termed melt days, acknowledging that some SWE may be lost by other processes}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces (a) Composite \textcolor {black}{$T_{\mathrm  {air}}$}\xspace  anomalies from the four USHCN stations in the greater Tahoe region study area for the month of March, from 1890 to 2026. Deviations from the 1980--2026 mean are depicted for one, two, and three standard deviation regions (shading). Anomalies are computed with respect to the 1980--2026 mean \textcolor {black}{$T_{\mathrm  {air}}$}\xspace  . (b) The same, but for a map-view of the \textcolor {black}{$T_{\mathrm  {air}}$}\xspace  anomaly of the gridded nClimGrid product.}}{14}{figure.3}\protected@file@percent }
\newlabel{fig:ushcn_data}{{3}{14}{(a) Composite \tair anomalies from the four USHCN stations in the greater Tahoe region study area for the month of March, from 1890 to 2026. Deviations from the 1980--2026 mean are depicted for one, two, and three standard deviation regions (shading). Anomalies are computed with respect to the 1980--2026 mean \tair . (b) The same, but for a map-view of the \tair anomaly of the gridded nClimGrid product}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textcolor {purple}{TODO: label columns a, b, and c}. (a) SWE values on March 1 and March 31 for the 12 SNOTEL sites in the study domain, labeled by three-digit station code. Each station has two sub-rows: The Mar 31 value is depicted in the top (gray shaded) row, and the Mar 1 value is depicted in the bottom (plain background) row. Climatological means and single standard deviations are depicted by open-circles with whiskers. The vertical dashed line depicts the 0 change line. Positive values indicated a gain of SWE and negative values indicate a loss of SWE. (b) the same as (a), but for the change in March SWE from the 1st to 31st. (c) Timeseries of SWE as a function of day of water year (days since October 1) for water year 2026 (red solid line). March is depicted as a gray shaded region. Mean, median, and one standard deviation are depicted by the blue solid line, blue dashed line, and blue shaded region. }}{14}{figure.4}\protected@file@percent }
\newlabel{fig:swechange}{{4}{14}{\todo {label columns a, b, and c}. (a) SWE values on March 1 and March 31 for the 12 SNOTEL sites in the study domain, labeled by three-digit station code. Each station has two sub-rows: The Mar 31 value is depicted in the top (gray shaded) row, and the Mar 1 value is depicted in the bottom (plain background) row. Climatological means and single standard deviations are depicted by open-circles with whiskers. The vertical dashed line depicts the 0 change line. Positive values indicated a gain of SWE and negative values indicate a loss of SWE. (b) the same as (a), but for the change in March SWE from the 1st to 31st. (c) Timeseries of SWE as a function of day of water year (days since October 1) for water year 2026 (red solid line). March is depicted as a gray shaded region. Mean, median, and one standard deviation are depicted by the blue solid line, blue dashed line, and blue shaded region}{figure.4}{}}
