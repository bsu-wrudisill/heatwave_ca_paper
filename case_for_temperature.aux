\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Idealized sensible heat fluxes ($H_s$) into a melting snowpack as a function of air temperature for four wind speeds (1, 5, 10, and 15 m s$^{-1}$) at a 12m height for open-conditions and a snow surface roughness of z$_0$=0.002m. Dashed lines show neutral-stability bulk transfer; solid lines show the same formulation with a stability correction applied as implemented in SUMMA. Grey points are SUMMA simulations colored by wind speed for snow covered, melting conditions where Ri $>$ 0.}}{17}{figure.12}\protected@file@percent }
\newlabel{fig:idealized_sens_heat}{{12}{17}{Idealized sensible heat fluxes ($H_s$) into a melting snowpack as a function of air temperature for four wind speeds (1, 5, 10, and 15 m s$^{-1}$) at a 12m height for open-conditions and a snow surface roughness of z$_0$=0.002m. Dashed lines show neutral-stability bulk transfer; solid lines show the same formulation with a stability correction applied as implemented in SUMMA. Grey points are SUMMA simulations colored by wind speed for snow covered, melting conditions where Ri $>$ 0}{figure.12}{}}
