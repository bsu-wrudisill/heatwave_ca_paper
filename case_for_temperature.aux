\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {(a)} The northern Sierra Nevada study region with terrain elevation. Outlines depict the Yuba, North Fork American, Lake Tahoe, and Truckee HUC8 watershed boundaries. Red open diamonds depict the location of NRCS SNOTEL sites, open black circles show the location of the four USHCN stations in the region, and the open blue square depicts the CSSL energy balance site. \textbf  {(b)} The CSSL meteorological tower in winter, \textbf  {(c)} a close-up view of the Cambpell CNR4 radiometer and IRGASON eddy covariance system, and \textbf  {(d)} an aerial overview of the CSSL site. The location of the forest meteorological tower (not shown) is located just outside of the frame. }}{10}{figure.1}\protected@file@percent }
\newlabel{fig:region_map}{{1}{10}{\textbf {(a)} The northern Sierra Nevada study region with terrain elevation. Outlines depict the Yuba, North Fork American, Lake Tahoe, and Truckee HUC8 watershed boundaries. Red open diamonds depict the location of NRCS SNOTEL sites, open black circles show the location of the four USHCN stations in the region, and the open blue square depicts the CSSL energy balance site. \textbf {(b)} The CSSL meteorological tower in winter, \textbf {(c)} a close-up view of the Cambpell CNR4 radiometer and IRGASON eddy covariance system, and \textbf {(d)} an aerial overview of the CSSL site. The location of the forest meteorological tower (not shown) is located just outside of the frame}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces  \textbf  {(a)} The 500 mb geopotential height anomaly during the March 2026 heatwave from ERA5 for six days across the western USA. The study region outlined by a black rectangle. Gray stippling indicates regions with a geopotential height greater than 2-$\sigma $ above the 1950-2022 mean for the month of March. \textbf  {(b-c)} shows the timeseries of meteorological conditions at CSSL prior to and during the heatwave event. \textbf  {(b)} depicts daily average air temperature and daily precipitation rate. Days with a majority of rain (red) and a majority of snowfall (blue) are differentiated. \textbf  {(c)} depicts the daily SWE and the one-day change in SWE (dSWE; right axis). Days with a positive dSWE (blue) are denoted by accumulation and days with a negative dSWE (red) are termed melt days, acknowledging that some SWE may be lost by other processes. }}{11}{figure.2}\protected@file@percent }
\newlabel{fig:era5_anoms}{{2}{11}{\textbf {(a)} The 500 mb geopotential height anomaly during the March 2026 heatwave from ERA5 for six days across the western USA. The study region outlined by a black rectangle. Gray stippling indicates regions with a geopotential height greater than 2-$\sigma $ above the 1950-2022 mean for the month of March. \textbf {(b-c)} shows the timeseries of meteorological conditions at CSSL prior to and during the heatwave event. \textbf {(b)} depicts daily average air temperature and daily precipitation rate. Days with a majority of rain (red) and a majority of snowfall (blue) are differentiated. \textbf {(c)} depicts the daily SWE and the one-day change in SWE (dSWE; right axis). Days with a positive dSWE (blue) are denoted by accumulation and days with a negative dSWE (red) are termed melt days, acknowledging that some SWE may be lost by other processes}{figure.2}{}}
