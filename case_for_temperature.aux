\newlabel{fig:canradeffect}{{9}{18}{Examining the behavior of the canopy longwave radiative effect (CanRE): (a) CanRE vs. \tair for the entirety of the SUMMA model record (2000---2026), (b) The difference between the canopy temperature and \tair as a function of time-of-day in local time (c) the same as (b), but for CanRE, (d) a timeseries of \tair , canopy temperature, and the VIIRS/Suomi-NPP LST product for the CSSL site during the month of March}{figure.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces The cirrus cloud radiative effect (cCRE) during March 2026. (a) cCRE versus near-surface \textcolor {black}{$T_{\mathrm  {air}}$}\xspace  and column precipitable water vapor (PWV). Dashed lines are linear regressions for each PWV bin. (b) Depicts a MODIS true-color image of cirrus cloud advection from the south into the study area on the afternoon of March 22nd, 2026. }}{19}{figure.10}\protected@file@percent }
\newlabel{fig:cirrus_longwave}{{10}{19}{The cirrus cloud radiative effect (cCRE) during March 2026. (a) cCRE versus near-surface \tair and column precipitable water vapor (PWV). Dashed lines are linear regressions for each PWV bin. (b) Depicts a MODIS true-color image of cirrus cloud advection from the south into the study area on the afternoon of March 22nd, 2026}{figure.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Factors explaining \textcolor {black}{$SW_{\mathrm  {net}}$}\xspace  during the March heatwave. (a) Solar insolation (\textcolor {black}{$SW\downarrow $}\xspace  ) during heatwave, (b) snow $\alpha $ observed by CSSL, modelled by SUMMA, and retrieved from remote sensing (SPIRES) at the CSSL site, and (c) AlbRE, or the difference between fresh snow \textcolor {black}{$R_{\mathrm  {net}}$}\xspace  and observed \textcolor {black}{$R_{\mathrm  {net}}$}\xspace  for each $\alpha $ product or observation.}}{19}{figure.11}\protected@file@percent }
\newlabel{fig:albedo}{{11}{19}{Factors explaining \swnet during the March heatwave. (a) Solar insolation (\swdn ) during heatwave, (b) snow $\alpha $ observed by CSSL, modelled by SUMMA, and retrieved from remote sensing (SPIRES) at the CSSL site, and (c) AlbRE, or the difference between fresh snow \rnet and observed \rnet for each $\alpha $ product or observation}{figure.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces \textcolor {purple}{TODO: Move LW plot to a separate figure} (a) Idealized sensible heat fluxes ($H_s$) into a melting snowpack as a function of air temperature for four wind speeds (1, 5, 10, and 15 m s$^{-1}$) at a 12m height for open-conditions and a snow surface roughness of z$_0$=0.002m. Dashed lines show neutral-stability bulk transfer; solid lines show the same formulation with a stability correction applied as implemented in SUMMA. (b) the same as (a), but for $H_l$ with a fixed RH of 25\%. (c) Clear-sky \textcolor {black}{$LW_{\mathrm  {net}}$}\xspace  as a function of \textcolor {black}{$T_{\mathrm  {air}}$}\xspace  and RH over a 0\textcolor {black}{$^\circ $C}\xspace  snowpack using the \cite  {Brutsaert1975-jl} formulation for \textcolor {black}{$LW\downarrow $}\xspace  , and (d) The thermodynamic limitation of sublimation as a function of \textcolor {black}{$T_{\mathrm  {air}}$}\xspace  , depicting the maximum RH that permits sublimation from a 0 \textcolor {black}{$^\circ $C}\xspace  snowpack. }}{20}{figure.12}\protected@file@percent }
\newlabel{fig:idealized_sens_heat}{{12}{20}{\todo {Move LW plot to a separate figure} (a) Idealized sensible heat fluxes ($H_s$) into a melting snowpack as a function of air temperature for four wind speeds (1, 5, 10, and 15 m s$^{-1}$) at a 12m height for open-conditions and a snow surface roughness of z$_0$=0.002m. Dashed lines show neutral-stability bulk transfer; solid lines show the same formulation with a stability correction applied as implemented in SUMMA. (b) the same as (a), but for $H_l$ with a fixed RH of 25\%. (c) Clear-sky \lwnet as a function of \tair and RH over a 0\degrc snowpack using the \cite {Brutsaert1975-jl} formulation for \lwdn , and (d) The thermodynamic limitation of sublimation as a function of \tair , depicting the maximum RH that permits sublimation from a 0 \degrc snowpack}{figure.12}{}}
